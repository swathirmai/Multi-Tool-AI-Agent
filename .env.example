# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenWeatherMap API key for weather lookups
# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# LLM model (default: claude-sonnet-4-6)
MODEL_NAME=claude-sonnet-4-6

# Embeddings model (runs locally, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Paths
FAISS_INDEX_PATH=data/vectorstore/faiss_index
DOCS_DIR=data/sample_docs

# RAG chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVER_K=4
